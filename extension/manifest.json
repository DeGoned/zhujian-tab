{
  "manifest_version": 3,
  "name": "zhujian-tab",
  "version": "1.1.0",
  "description": "tab-out 的 fork：新标签页 = tab 仪表盘 + 待办 + Mac 系统通知提醒。Tab 深度绑定 todo、今日/项目双 view、全局快捷键捕获、任意时间点 + 9 种重复规则。",
  "permissions": ["tabs", "activeTab", "storage", "scripting", "alarms", "notifications"],
  "host_permissions": ["<all_urls>"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js", "type": "module" },
  "commands": {
    "open-capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "打开 todo 捕获浮窗"
    }
  },
  "action": {
    "default_title": "zhujian-tab",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
